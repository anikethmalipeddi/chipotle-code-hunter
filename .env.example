# Account to monitor. Do not include the @ symbol.
TARGET_USERNAME=ChipotleTweets

# Chipotle text-to-claim destination.
SMS_NUMBER=888222

# Monitoring backend. auto uses X API if X_BEARER_TOKEN is set, otherwise free Nitter RSS.
# Options: auto, x_api, nitter_rss, ntscraper
MONITOR_BACKEND=auto
X_BEARER_TOKEN=
REQUEST_MIN_INTERVAL_SECONDS=2
NITTER_RSS_BASE_URL=https://nitter.net

# Polling and fetch behavior.
POLL_INTERVAL_SECONDS=30
FETCH_COUNT=5
MAX_BACKOFF_SECONDS=300

# Detection sensitivity. Higher means fewer alerts; lower means more alerts.
DETECTION_THRESHOLD=6

# Alert behavior.
AUTO_OPEN_MESSAGES=true

# Off by default. If true, sends the detected code through macOS Messages.
# Test with DRY_RUN=true before using this for real.
AUTO_SEND_MESSAGES=false

COPY_CODE_TO_CLIPBOARD=true
PLAY_SOUND=true
ALERT_SOUND=/System/Library/Sounds/Sosumi.aiff
ALERT_REPEAT_COUNT=3

# Optional: only used when MONITOR_BACKEND=ntscraper.
NITTER_INSTANCE=
NTSCRAPER_LOG_LEVEL=0

# Local state and logging.
STATE_FILE=.chipotle-code-hunter-seen.json
LOG_LEVEL=INFO

# Set true to disable sounds, clipboard writes, and opening Messages.
DRY_RUN=false
